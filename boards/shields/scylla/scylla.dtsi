#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/zmk/input_transform.h>
#include <dt-bindings/gpio/gpio.h>
#include <physical_layouts.dtsi>
#include <dt-bindings/zmk/pointing.h>

/ {
    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;
        poll-period-ms = <25>;

    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <6>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)     RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)     RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)     RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)     RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11)
                                    RC(4,3) RC(4,4) RC(4,5)     RC(4,6) RC(4,7) RC(4,8)
                                            RC(5,4) RC(5,5)     RC(5,6) RC(5,7)
        >;

    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        kscan = <&kscan0>;
        transform = <&default_transform>;
        keys //                    w   h   x    y   rot  rx  ry
            = <&key_physical_attrs 100 100   0  42  0 0 0> // Row 1
            , <&key_physical_attrs 100 100 100  13  0 0 0>
            , <&key_physical_attrs 100 100 200   0  0 0 0>
            , <&key_physical_attrs 100 100 300  13  0 0 0>
            , <&key_physical_attrs 100 100 400  42  0 0 0>
            , <&key_physical_attrs 100 100 500  55  0 0 0>  // Esquerda
            , <&key_physical_attrs 100 100 800  55  0 0 0>
            , <&key_physical_attrs 100 100 900  42  0 0 0>
            , <&key_physical_attrs 100 100 1000 13  0 0 0>
            , <&key_physical_attrs 100 100 1100  0  0 0 0>
            , <&key_physical_attrs 100 100 1200 13  0 0 0>
            , <&key_physical_attrs 100 100 1300 42  0 0 0> // Direita
            , <&key_physical_attrs 100 100   0 142  0 0 0> // Row 2
            , <&key_physical_attrs 100 100 100 113  0 0 0>
            , <&key_physical_attrs 100 100 200 100  0 0 0>
            , <&key_physical_attrs 100 100 300 113  0 0 0>
            , <&key_physical_attrs 100 100 400 142  0 0 0>
            , <&key_physical_attrs 100 100 500 155  0 0 0>
            , <&key_physical_attrs 100 100 800 155  0 0 0>
            , <&key_physical_attrs 100 100 900 142  0 0 0>
            , <&key_physical_attrs 100 100 1000 113 0 0 0>
            , <&key_physical_attrs 100 100 1100 100 0 0 0>
            , <&key_physical_attrs 100 100 1200 113 0 0 0>
            , <&key_physical_attrs 100 100 1300 142 0 0 0>
            , <&key_physical_attrs 100 100   0 242  0 0 0> // Row 3
            , <&key_physical_attrs 100 100 100 213  0 0 0>
            , <&key_physical_attrs 100 100 200 200  0 0 0>
            , <&key_physical_attrs 100 100 300 213  0 0 0>
            , <&key_physical_attrs 100 100 400 242  0 0 0>
            , <&key_physical_attrs 100 100 500 255  0 0 0>
            , <&key_physical_attrs 100 100 800 255  0 0 0>
            , <&key_physical_attrs 100 100 900 242  0 0 0>
            , <&key_physical_attrs 100 100 1000 213 0 0 0>
            , <&key_physical_attrs 100 100 1100 200 0 0 0>
            , <&key_physical_attrs 100 100 1200 213 0 0 0>
            , <&key_physical_attrs 100 100 1300 242 0 0 0>
            , <&key_physical_attrs 100 100   0 342  0 0 0> // Row 4
            , <&key_physical_attrs 100 100 100 313  0 0 0>
            , <&key_physical_attrs 100 100 200 300  0 0 0>
            , <&key_physical_attrs 100 100 300 313  0 0 0>
            , <&key_physical_attrs 100 100 400 342  0 0 0>
            , <&key_physical_attrs 100 100 500 355  0 0 0>
            , <&key_physical_attrs 100 100 800 355  0 0 0>
            , <&key_physical_attrs 100 100 900 342  0 0 0>
            , <&key_physical_attrs 100 100 1000 313 0 0 0>
            , <&key_physical_attrs 100 100 1100 300 0 0 0>
            , <&key_physical_attrs 100 100 1200 313 0 0 0>
            , <&key_physical_attrs 100 100 1300 342 0 0 0>
            , <&key_physical_attrs 100 100 300 450  0 0 0> // Row 5
            , <&key_physical_attrs 100 100 400 450  0 0 0>
            , <&key_physical_attrs 100 100 500 450  0 0 0>
            , <&key_physical_attrs 100 100 800 450  0 0 0>
            , <&key_physical_attrs 100 100 900 450  0 0 0>
            , <&key_physical_attrs 100 100 1000 450 0 0 0>
            , <&key_physical_attrs 100 100 420 550  0 0 0> // Row 6
            , <&key_physical_attrs 100 100 520 550  0 0 0>
            , <&key_physical_attrs 100 100 780 550  0 0 0>
            , <&key_physical_attrs 100 100 880 550  0 0 0>
            ;
    };

    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &physical_layout0;
    };
    
};